# ============================================================
# All Sorted — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#   nano .env
# ============================================================

# === REQUIRED ===
# Your name (shown in the dashboard header and agent messages)
USER_FIRST_NAME=
USER_FULL_NAME=
USER_EMAIL=

# Name of your AI agent (displayed throughout the UI)
USER_AGENT_NAME=Sorted

# === AI (required for The Genie / AI features) ===
ANTHROPIC_API_KEY=

# === TELEGRAM (optional) ===
# Create a bot at https://t.me/BotFather — takes 2 minutes
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === STRIPE (optional) ===
# Revenue dashboard, subscription tracking, promo codes
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# === GOOGLE (optional) ===
# Gmail, Calendar, Drive, Search Console integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === NOTION (optional) ===
# Sync notes and project context to Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# === PORTS (change only if defaults conflict with other services) ===
MC_PORT=3000
